@page "/professional/services/{id:int}/review"
@attribute [Authorize(Roles = "Handyman")]

<section class="narrow-page page-section">
    <div class="card panel">
        <p class="page-eyebrow">Review</p>
        <h1>Review Customer</h1>
        <p class="page-description">Handyman feedback will be added after completed services are available.</p>
        <a class="btn btn-outline-primary" href="/professional/services">Back to all jobs</a>
    </div>
</section>

@code {
    [Parameter] public int Id { get; set; }
}