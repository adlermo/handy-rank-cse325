@page "/professional/services"
@attribute [Authorize(Roles = "Handyman")]

<section class="page-section">
    <div class="page-header">
        <p class="page-eyebrow">Handyman workspace</p>
        <h1>Available Jobs</h1>
        <p class="page-description">Review open customer requests and accept jobs that match your skills.</p>
    </div>

    <div class="card empty-state">
        <span class="status-pill">No open jobs</span>
        <h2>Nothing available right now</h2>
        <p class="muted-text">New customer requests will appear here when the marketplace has active jobs.</p>
    </div>
</section>
