@page "/professional/services"
@attribute [Authorize(Roles = "Handyman")]

@using HandyRank.Components.Shared
@using HandyRank.Features.Marketplace.Services
@inject JobDiscoveryService Jobs

<section class="page-section">
    <div class="page-header">
        <p class="page-eyebrow">Handyman workspace</p>
        <h1>Available Jobs</h1>
        <p class="page-description">
            Review open customer requests and accept jobs that match your skills.
        </p>
    </div>


    @* Tab switcher for open jobs vs my accepted jobs *@
    <div class="tabs">
        <button class='tab @(activeTab == "open" ? "active" : "")' @onclick='() => SetTab("open")'>
            Open Jobs
        </button>

        <button class='tab @(activeTab == "my" ? "active" : "")' @onclick='() => SetTab("my")'>
            My Jobs
        </button>
    </div>

    <div class="service-list">
        @if (activeTab == "open")
        {
            @foreach (ServiceRequest job in openJobs)
            {
                <ServiceCard Request="job" IsCustomer="false" OnAccept="AcceptJob" />
            }
        }
        else if (activeTab == "my")
        {
            @foreach (ServiceRequest job in myJobs)
            {
                <ServiceCard Request="job" IsCustomer="false" />
            }
        }
    </div>

</section>

@code {
    bool loading = false;

    string activeTab = "open";

    List<ServiceRequest> openJobs = new();
    List<ServiceRequest> myJobs = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadJobs();
    }

    async Task LoadJobs()
    {
        openJobs = await Jobs.GetAvailableJobs();
        myJobs = await Jobs.GetMyJobs();
    }

    async Task AcceptJob(int id)
    {
        if (loading) return;

        loading = true;

        await Jobs.AcceptJob(id);
        openJobs = await Jobs.GetAvailableJobs();
        myJobs = await Jobs.GetMyJobs();

        loading = false;
    }

    void SetTab(string tab)
    {
        activeTab = tab;
    }
}