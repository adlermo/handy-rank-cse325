@page "/profile"
@attribute [Authorize]
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using System.Security.Claims
@using HandyRank.Data
@using HandyRank.Domain.Enums
@using HandyRank.Features.Location.DTOs
@using HandyRank.Models
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db
@inject IHttpClientFactory HttpFactory
@inject AuthenticationStateProvider AuthenticationStateProvider

<section class="narrow-page page-section">
    <div class="page-header">
        <p class="page-eyebrow">Account</p>

        @if (isHandyman)
        {
            <div class="profile-hero">
                <h1>@rank</h1>
                <p class="muted-text">@xp XP • @(progress)% to next level</p>

                <div class="xp-bar">
                    <div class="xp-fill" style="width:@(progress)%"></div>
                </div>
                <br />
                <small>@jobsCompleted jobs completed</small>
                <p class="muted-text">Keep going. You're building your reputation.</p>
            </div>
        }
    </div>

    <div class="card panel">
        @if (isLoading)
        {
            <p class="muted-text">Loading profile...</p>
        }
        else
        {
            @if (!string.IsNullOrWhiteSpace(statusMessage))
            {
                <div class="alert @(isError ? "alert-danger" : "alert-success")" role="alert">
                    @statusMessage
                </div>
            }

            <EditForm Model="form" OnValidSubmit="SaveAsync" class="auth-form">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <section class="profile-form-section">
                    <h2>Account Info</h2>

                    <div class="profile-grid">
                        <div class="profile-row">
                            <span class="profile-label">Email</span>
                            <span class="profile-value">@email</span>
                        </div>
                        <div class="profile-row">
                            <span class="profile-label">Role</span>
                            <span class="profile-value">@role</span>
                        </div>
                    </div>

                    <div class="form-field">
                        <label for="name" class="form-label">Name</label>
                        <InputText id="name" class="form-control" @bind-Value="form.Name" />
                        <ValidationMessage For="() => form.Name" />
                    </div>

                    <div class="form-field">
                        <label for="bio" class="form-label">Bio</label>
                        <InputTextArea id="bio" class="form-control" rows="5" @bind-Value="form.Bio" />
                        <ValidationMessage For="() => form.Bio" />
                    </div>

                    <div class="form-field">
                        <label for="location" class="form-label">Location</label>
                        <InputText id="location" class="form-control" @bind-Value="form.Location"
                                   @oninput="OnLocationInput" />

                        @if (suggestions.Any())
                        {
                            <ul class="autocomplete-list">
                                @foreach (var s in suggestions)
                                {
                                    <li @onclick="() => SelectLocation(s)">
                                        @s.Description
                                    </li>
                                }
                            </ul>
                        }
                        <ValidationMessage For="() => form.Location" />
                    </div>
                </section>

                @if (isHandyman)
                {
                    <section class="profile-form-section">
                        <h2>Professional Info</h2>

                        <div class="form-field">
                            <div class="suggested-skills">
                                @foreach (var skill in SuggestedSkills)
                                {
                                    <button type="button" class="skill-suggestion" @onclick="() => AddSkill(skill)">
                                        + @skill
                                    </button>
                                }
                            </div>

                            <label for="skills" class="form-label">Skills</label>
                            <InputText id="skills" class="form-control" @bind-Value="form.Skills"
                                       @onblur="() => form.Skills = NormalizeSkills(form.Skills)" />
                            <ValidationMessage For="() => form.Skills" />

                            @if (!string.IsNullOrWhiteSpace(form.Skills))
                            {
                                <div class="skill-tags">
                                    @foreach (var skill in form.Skills.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                    {
                                        <span class="skill-tag">
                                            @skill.Trim()
                                            <button type="button" class="remove-skill" @onclick="() => RemoveSkill(skill)">
                                                ×
                                            </button>
                                        </span>
                                    }
                                </div>
                            }
                        </div>

                        <div class="profile-grid">
                            <div class="profile-row">
                                <span class="profile-label">Rank</span>
                                <span class="profile-value">@rank</span>
                            </div>
                            <div class="profile-row">
                                <span class="profile-label">XP</span>
                                <span class="profile-value">@xp</span>
                            </div>
                        </div>
                    </section>
                }

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary" disabled="@isSaving">
                        @(isSaving ? "Saving..." : "Save Profile")
                    </button>
                </div>
            </EditForm>
        }
    </div>
</section>

@code {
    private readonly ProfileForm form = new();
    private int userId;
    private string email = string.Empty;
    private string role = string.Empty;
    private string rank = "New";
    private int xp;
    private int jobsCompleted;
    private bool isHandyman;
    private bool isLoading = true;
    private bool isSaving;
    private bool isError;
    private string? statusMessage;
    private int progress;

    private List<LocationSuggestion> suggestions = new();

    private static readonly List<string> SuggestedSkills = new()
    {
        "plumbing",
        "electrical",
        "carpentry",
        "drywall",
        "painting",
        "furniture assembly",
        "tv mounting"
    };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();

        if (!TryGetUserId(authState.User, out userId))
        {
            isError = true;
            statusMessage = "Could not load your account.";
            isLoading = false;
            return;
        }

        var user = await Db.Users
            .Include(user => user.HandymanProfile)
            .AsNoTracking()
            .SingleOrDefaultAsync(user => user.Id == userId);

        if (user is null)
        {
            isError = true;
            statusMessage = "Could not load your profile.";
            isLoading = false;
            return;
        }

        email = user.Email;
        role = user.Role.ToString();
        isHandyman = user.Role == UserRole.Handyman;
        form.RequireSkills = isHandyman;
        form.Name = user.Name;
        form.Bio = user.Bio;
        form.Location = user.Location;

        if (isHandyman)
        {
            form.Skills = user.HandymanProfile?.Skills ?? string.Empty;
            rank = user.HandymanProfile?.Rank ?? "New";
            xp = user.HandymanProfile?.XP ?? 0;
            jobsCompleted = user.HandymanProfile?.TotalJobsCompleted ?? 0;
        }

        var (min, max) = GetRange(xp);
        progress = (max - min) == 0 ? 0 : (xp - min) * 100 / (max - min);

        isLoading = false;
    }

    private async Task SaveAsync()
    {
        isSaving = true;
        isError = false;
        statusMessage = null;

        var user = await Db.Users
            .Include(user => user.HandymanProfile)
            .SingleOrDefaultAsync(user => user.Id == userId);

        if (user is null)
        {
            isError = true;
            statusMessage = "Could not save your profile.";
            isSaving = false;
            return;
        }

        user.Name = form.Name.Trim();
        user.Bio = form.Bio.Trim();
        user.Location = form.Location.Trim();
        user.LocationName = form.LocationName;
        user.Latitude = form.Latitude;
        user.Longitude = form.Longitude;

        if (isHandyman)
        {
            if (user.HandymanProfile is null)
            {
                user.HandymanProfile = new HandymanProfile { UserId = user.Id };
                Db.HandymanProfiles.Add(user.HandymanProfile);
            }

            user.HandymanProfile.Skills = NormalizeSkills(form.Skills);
            rank = user.HandymanProfile.Rank;
            xp = user.HandymanProfile.XP;
        }

        await Db.SaveChangesAsync();

        statusMessage = "Profile saved.";
        isSaving = false;
    }

    private async Task OnLocationInput(ChangeEventArgs e)
    {
        var input = e.Value?.ToString();

        if (string.IsNullOrWhiteSpace(input) || input.Length < 3)
        {
            suggestions.Clear();
            return;
        }

        var client = HttpFactory.CreateClient("api");
        var result = await client.GetFromJsonAsync<List<LocationSuggestion>>(
    $"api/location/autocomplete?input={input}");

        suggestions = result ?? new();
    }

    private async Task SelectLocation(LocationSuggestion suggestion)
    {
        form.Location = suggestion.Description;
        form.LocationName = suggestion.Description;

        suggestions.Clear();

        var client = HttpFactory.CreateClient("api");

        var response =
            await client.GetAsync($"api/location/details?placeId={suggestion.PlaceId}");

        if (!response.IsSuccessStatusCode) return;

        var coords =
            await response.Content.ReadFromJsonAsync<(double lat, double lng)?>();

        if (coords is not null)
        {
            form.Latitude = coords.Value.lat;
            form.Longitude = coords.Value.lng;
        }
    }

    private async Task LoadLocationDetails(string placeId)
    {
        var client = HttpFactory.CreateClient("api");
        var result = await client.GetFromJsonAsync<GooglePlaceDetailsResponse>(
            $"api/location/details?placeId={placeId}");

        var location = result?.result?.geometry?.location;

        if (location is not null)
        {
            form.Latitude = location.lat;
            form.Longitude = location.lng;
        }
    }

    private static string NormalizeSkills(string input)
    {
        if (string.IsNullOrWhiteSpace(input))
            return string.Empty;

        var skills = input
            .Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(s => s.Trim().ToLower())
            .Where(s => !string.IsNullOrWhiteSpace(s))
            .Distinct();

        return string.Join(",", skills);
    }

    private void AddSkill(string skill)
    {
        var current = form.Skills
            .Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(s => s.Trim().ToLower())
            .ToList();

        if (!current.Contains(skill))
            current.Add(skill);

        form.Skills = string.Join(",", current);
    }

    private void RemoveSkill(string skillToRemove)
    {
        var updated = form.Skills
            .Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(s => s.Trim().ToLower())
            .Where(s => s != skillToRemove.Trim().ToLower())
            .ToList();

        form.Skills = string.Join(",", updated);
    }

    private static bool TryGetUserId(ClaimsPrincipal user, out int userId)
    {
        var userIdValue = user.FindFirstValue(ClaimTypes.NameIdentifier);
        return int.TryParse(userIdValue, out userId);
    }

    private (int min, int max) GetRange(int xp)
    {
        if (xp < 200) return (0, 200);
        if (xp < 500) return (200, 500);
        if (xp < 1000) return (500, 1000);
        if (xp < 2000) return (1000, 2000);
        if (xp < 4000) return (2000, 4000);
        if (xp < 7000) return (4000, 7000);

        return (7000, 10000);
    }

    private sealed class ProfileForm : IValidatableObject
    {
        [Required]
        [StringLength(User.MaxNameLength)]
        public string Name { get; set; } = string.Empty;

        [Required]
        [StringLength(User.MaxBioLength)]
        public string Bio { get; set; } = string.Empty;

        [Required]
        [StringLength(User.MaxLocationLength)]
        public string Location { get; set; } = string.Empty;

        public string LocationName { get; set; } = string.Empty;
        public double? Latitude { get; set; }
        public double? Longitude { get; set; }

        [StringLength(HandymanProfile.MaxSkillsLength)]
        public string Skills { get; set; } = string.Empty;

        public bool RequireSkills { get; set; }

        public IEnumerable<ValidationResult> Validate(ValidationContext validationContext)
        {
            if (RequireSkills && string.IsNullOrWhiteSpace(Skills))
            {
                yield return new ValidationResult(
                    "Skills is required.",
                    [nameof(Skills)]);
            }
        }
    }
}
