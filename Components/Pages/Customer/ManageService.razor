@page "/customer/services/{id:int}"
@attribute [Authorize(Roles = "Customer")]

<section class="narrow-page page-section">
    <div class="card panel">
        <p class="page-eyebrow">Service completion</p>
        <h1>Complete Service</h1>
        <p class="page-description">Completion actions will appear here once service details are connected.</p>
        <a class="btn btn-outline-primary" href="/customer/services">Back to services</a>
    </div>
</section>
