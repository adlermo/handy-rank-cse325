@page "/customer/services/{id:int}"
@using HandyRank.Domain.Enums
@using HandyRank.Features.ServiceRequests.Services
@using HandyRank.Models
@attribute [Authorize(Roles = "Customer")]
@inject CustomerRequestService Service

<section class="narrow-page page-section">
    <div class="card panel">
        <p class="page-eyebrow">Service Request Management</p>
        <br />

        @if (request is not null)
        {
            <div class="service-header">
                <h2>@request.Title</h2>
                <span class="status @GetStatusClass(request.Status)">
                    @request.Status
                </span>
            </div>

            <p class="service-description">@request.Description</p>

            <div class="meta">
                <span>🔧 @request.Category?.Name</span>
                <span>📍 @request.Location</span>
            </div>
        
            @if (request.Professional == null && applicants.Any())
            {
                <h2>Applicants</h2>

                @foreach (var pro in applicants)
                {
                    <div class="applicant-card">
                        <div class="applicant-info">
                            <p><strong>@pro.Name</strong></p>
                            <p>@pro.Bio</p>
                            <p><small class="applicant-skills">@pro.Skills</small></p>
                            <p><small>Applied @pro.AppliedAt.ToShortDateString()</small></p>
                        </div>

                        <button class="btn btn-primary" @onclick="() => SelectProfessional(pro.ProfessionalId)">
                            Select
                        </button>
                    </div>
                }
            }
            else if (request.Professional == null)
            {
                <p>No professionals applied yet</p>
            }

            @if (request.Professional != null)
            {
                <div class="selected-pro">
                    <h2>Assigned Professional</h2>
                    <p>@request.Professional.Name</p>
                </div>
            }

            if (request.Status == ServiceRequestStatus.Pending && request.Professional != null)
            {
                <button class="btn btn-success" @onclick="MarkCompleted">
                    Mark as Completed
                </button>
            }
            else if (request.Status == ServiceRequestStatus.Completed)
            {
                if (review is null)
                {
                    <a class="btn btn-outline-primary" href="/customer/services/@request.Id/review">
                        Leave Review
                    </a>
                }
                else
                {
                    <div class="review-display">
                        @if (!string.IsNullOrWhiteSpace(review.Comment))
                        {
                            <p class="comment">"@review.Comment"</p>
                        }

                        <div class="stars">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <span class="star@(i <= review.Rating ? " active" : "")">★</span>
                            }
                        </div>

                        <div class="tags">
                            @foreach (var tag in review.Tags)
                            {
                                <span class="tag selected">@tag</span>
                            }
                        </div>

                    </div>
                }
            }
        }
        
        @* <a class="btn btn-outline-primary" href="/customer/services">Back to services</a> *@
    </div>
</section>

@code {
    [Parameter] public int Id { get; set; }
    Review? review;
    ServiceRequest? request;
    List<ApplicantDto> applicants = new();

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    async Task Load()
    {
        var result = await Service.GetWithReview(Id);

        request = result.request;
        review = result.review;

        applicants = await Service.GetApplicants(Id);
    }

    async Task SelectProfessional(int proId)
    {
        await Service.SelectProfessional(Id, proId);

        await Load();
    }

    async Task MarkCompleted()
    {
        await Service.MarkCompleted(Id);

        request = await Service.GetById(Id);
    }

    string GetStatusClass(ServiceRequestStatus status) => status switch
    {
        ServiceRequestStatus.Open => "status-open",
        ServiceRequestStatus.Pending => "status-pending",
        ServiceRequestStatus.Completed => "status-completed",
        _ => ""
    };
}