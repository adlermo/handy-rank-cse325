@page "/customer/services/create"
@using HandyRank.Domain.Categories
@using HandyRank.Features.ServiceRequests.Services
@attribute [Authorize(Roles = "Customer")]
@inject ServiceRequestService Service
@inject CategoryService CategoryService
@inject NavigationManager Navigation

<section class="narrow-page page-section">
    <div class="page-header">
        <p class="page-eyebrow">New request</p>
        <h1>Create Service</h1>
        <p class="page-description">This layout is ready for the service creation flow.</p>
    </div>

    <EditForm Model="request" OnValidSubmit="HandleSubmit" FormName="createRequest">
        <DataAnnotationsValidator />
        <ValidationSummary />
        <div class="card panel">
            <div class="auth-form">

                <div class="form-field">
                    <label class="form-label" for="title">Service title</label>
                    <InputText id="title" class="form-control" type="text" placeholder="Example: Fix kitchen sink"
                               @bind-Value="request.Title" />
                </div>

                <div class="form-field">
                    <label class="form-label" for="description">Description</label>
                    <InputTextArea id="description" class="form-control" rows="4" placeholder="Details will go here."
                                   @bind-Value="request.Description">
                    </InputTextArea>
                </div>

                <div class="form-field">
                    <label class="form-label">Location</label>
                    <InputText id="location" class="form-control" @bind-Value="request.Location" />
                </div>

                <div class="form-field">
                    <label class="form-label">Category</label>
                    <InputSelect TValue="int" class="form-control" @bind-Value="request.CategoryId">
                        @foreach (var c in categories)
                        {
                            <option @key="c.Id" value="@(c.Id)">@c.Name</option>
                        }
                    </InputSelect>
                </div>

            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    Create Service
                </button>

                <a class="btn btn-link" href="/customer/services">
                    Back to services
                </a>
            </div>
        </div>
    </EditForm>

</section>

@code {
    CreateServiceRequestDto request = new();
    List<ServiceCategory> categories = new();

    protected override async Task OnInitializedAsync()
    {
        categories = await CategoryService.GetAll();
    }

    async Task HandleSubmit()
    {
        Console.WriteLine($"CategoryId Form: {request.CategoryId}");
        await Service.CreateCustomerRequest(request);
        Navigation.NavigateTo("/customer/services");
    }
}