@page "/customer/services/create"
@using System.ComponentModel.DataAnnotations
@using HandyRank.Domain.Categories
@using HandyRank.Features.Location.DTOs
@using HandyRank.Features.ServiceRequests.Services
@attribute [Authorize(Roles = "Customer")]
@inject CustomerRequestService Service
@inject CategoryService CategoryService
@inject NavigationManager Navigation
@inject IHttpClientFactory HttpFactory
@inject NavigationManager Nav

<section class="narrow-page page-section">
    <div class="page-header">
        <p class="page-eyebrow">New request</p>
        <h1>Create Service</h1>
        <p class="page-description">Describe what you need and we'll find the right pro.</p>
    </div>

    <EditForm Model="form" OnValidSubmit="HandleSubmit" FormName="createRequest">
        <DataAnnotationsValidator />

        <div class="card panel">
            <div class="auth-form">
                <div class="form-field">
                    <label class="form-label" for="title">Service title</label>
                    <InputText id="title" class="form-control" placeholder="Example: Fix kitchen sink"
                               @bind-Value="form.Title" />
                    <ValidationMessage For="() => form.Title" />
                </div>

                <div class="form-field">
                    <label class="form-label" for="description">Description</label>
                    <InputTextArea id="description" class="form-control" rows="4" placeholder="Details will go here."
                                   @bind-Value="form.Description" />
                    <ValidationMessage For="() => form.Description" />
                </div>

                <div class="form-field">
                    <label class="form-label">Location</label>
                    <InputText class="form-control" @bind-Value="form.Location" @oninput="OnLocationInput" />

                    @if (suggestions.Any())
                    {
                        <ul class="autocomplete-list">
                            @foreach (var s in suggestions)
                            {
                                <li @onclick="() => SelectLocation(s)">
                                    @s.Description
                                </li>
                            }
                        </ul>
                    }
                    <ValidationMessage For="() => form.Location" />
                </div>

                <div class="form-field">
                    <label class="form-label">Category</label>
                    <InputSelect TValue="int" class="form-control" @bind-Value="form.CategoryId">
                        <option value="0">Select a category</option>

                        @foreach (var c in categories)
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="() => form.CategoryId" />
                </div>

            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    Create Service
                </button>

                <a class="btn btn-link" href="/customer/services">
                    Back to services
                </a>
            </div>
        </div>
    </EditForm>

</section>

@code {
    private readonly CreateServiceForm form = new();
    private List<ServiceCategory> categories = new();
    private List<LocationSuggestion> suggestions = new();

    protected override async Task OnInitializedAsync()
    {
        categories = await CategoryService.GetAll();
    }

    private async Task HandleSubmit()
    {
        await Service.Create(new CreateServiceRequestDto
        {
            Title = form.Title,
            Description = form.Description,
            Location = form.Location,
            CategoryId = form.CategoryId
        });

        Navigation.NavigateTo("/customer/services");
    }

    private async Task OnLocationInput(ChangeEventArgs e)
    {
        var input = e.Value?.ToString();

        if (string.IsNullOrWhiteSpace(input) || input.Length < 3)
        {
            suggestions.Clear();
            return;
        }

        var client = HttpFactory.CreateClient();

        var result = await client.GetFromJsonAsync<List<LocationSuggestion>>(
            $"{Nav.BaseUri}api/location/autocomplete?input={input}");

        suggestions = result ?? new();
    }

    private async Task SelectLocation(LocationSuggestion suggestion)
    {
        form.Location = suggestion.Description;
        suggestions.Clear();

        var client = HttpFactory.CreateClient();

        var response = await client.GetAsync(
            $"{Nav.BaseUri}api/location/details?placeId={suggestion.PlaceId}");

        if (!response.IsSuccessStatusCode) return;

        var coords = await response.Content
            .ReadFromJsonAsync<(double lat, double lng)?>();

        // opcional (se quiser evoluir depois)
        // form.Latitude = coords?.lat;
        // form.Longitude = coords?.lng;
    }

    private class CreateServiceForm
    {
        [Required]
        [StringLength(100, MinimumLength = 5)]
        public string Title { get; set; } = string.Empty;

        [Required]
        [StringLength(1000, MinimumLength = 10)]
        public string Description { get; set; } = string.Empty;

        [Required]
        [StringLength(200)]
        public string Location { get; set; } = string.Empty;

        [Range(1, int.MaxValue, ErrorMessage = "Please select a category.")]
        public int CategoryId { get; set; }
    }
}