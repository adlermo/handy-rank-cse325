@using HandyRank.Domain.Enums
<ServiceCardBase Title="@Job.Title" Description="@Job.Description" Category="@Job.Category" Location="@Job.Location"
                 CreatedAt="@Job.CreatedAt" Status="@Job.Status.ToString()">

    @if (Job.Status == ServiceRequestStatus.Open)
    {
        @if (!Job.HasApplied)
        {
            <button class="btn btn-primary" @onclick="() => OnApply.InvokeAsync(Job.Id)">
                Apply
            </button>
        }
        else
        {
            <button class="btn btn-secondary" disabled>
                Applied ✅
            </button>
        }
    }

    @if (Job.Status == ServiceRequestStatus.Completed && Job.Rating != null)
    {
        <div class="review-preview">
            <span>⭐ @Job.Rating</span>

            @if (!string.IsNullOrWhiteSpace(Job.CommentPreview))
            {
                <p>"@Job.CommentPreview"</p>
            }
        </div>
    }
</ServiceCardBase>

@code {
    [Parameter] public JobCardDto Job { get; set; } = default!;
    [Parameter] public EventCallback<int> OnApply { get; set; }
}