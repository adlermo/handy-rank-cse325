@inherits LayoutComponentBase

<div class="app-shell">
    <header class="site-header">
        <nav class="site-nav">
            <a class="brand-link" href="/">
                <img src="/favicon-32x32.png" alt="GetMonks Logo" class="brand-logo" />
                <span>HandyRank</span>
            </a>

            <div class="nav-links">
                <AuthorizeView Roles="Customer">
                    <Authorized>
                        <a href="/customer/services">My Services</a>
                    </Authorized>
                </AuthorizeView>

                <AuthorizeView Roles="Handyman">
                    <Authorized>
                        <a href="/professional/services">Available Jobs</a>
                    </Authorized>
                </AuthorizeView>

                <AuthorizeView>
                    <Authorized Context="authContext">
                        <a class="user-link" href="/profile">@authContext.User.Identity?.Name</a>
                        <form method="post" action="/auth/logout" class="logout-form">
                            <AntiforgeryToken />
                            <button type="submit" class="nav-button">Logout</button>
                        </form>
                    </Authorized>
                    <NotAuthorized>
                        <a href="/login">Login</a>
                        <a class="nav-button" href="/signup">Sign Up</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </nav>
    </header>

    <main class="page-main">
        <article class="page-container">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>
